PORT=5000
MONGO_URI=mongodb://localhost:27017/online-course-platform
# Atlas Deployment String: mongodb+srv://<db_username>:<db_password>@cluster0.eyzjikl.mongodb.net/online-course-platform?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here

# SMTP Configuration (Optional - logs to console if empty)
